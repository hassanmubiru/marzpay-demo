# MarzPay sandbox API key (required) — used as `apiKey` when installing the MarzPay plugin.
# Obtain this from your MarzPay sandbox dashboard.
MARZPAY_API_KEY=your-marzpay-api-key

# MarzPay sandbox secret key (required) — used as `secretKey` when installing the MarzPay plugin.
# Obtain this from your MarzPay sandbox dashboard.
MARZPAY_SECRET_KEY=your-marzpay-secret-key

# MarzPay environment (optional) — must be `sandbox` or `production` when set.
# Defaults to `sandbox` if absent or empty.
MARZPAY_ENVIRONMENT=sandbox

# Public base URL of the app (required) — used to build the success-page URL.
APP_URL=http://localhost:3000

# TCP port the server binds to (required) — integer between 1 and 65535.
PORT=3000
# --- Supabase (optional locally; required for the Vercel deployment) ---
# When SUPABASE_URL and a key are set, the app uses the durable Supabase
# (append-only) Payment_Store via @streetjs/plugin-supabase instead of the
# in-process SQLite store. Leave these blank for local SQLite development.

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase API key. Prefer the SERVICE ROLE key (server-side only) so RLS is
# bypassed; alternatively use the anon key with RLS policies (see supabase/schema.sql).
# SUPABASE_KEY takes precedence; SUPABASE_SERVICE_ROLE_KEY is also accepted.
SUPABASE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
