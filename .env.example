# MarzPay sandbox API key (required) — used as `apiKey` when installing the MarzPay plugin.
# Obtain this from your MarzPay sandbox dashboard.
MARZPAY_API_KEY=your-marzpay-api-key

# MarzPay sandbox secret key (required) — used as `secretKey` when installing the MarzPay plugin.
# Obtain this from your MarzPay sandbox dashboard.
MARZPAY_SECRET_KEY=your-marzpay-secret-key

# MarzPay environment (optional) — must be `sandbox` or `production` when set.
# Defaults to `sandbox` if absent or empty.
MARZPAY_ENVIRONMENT=sandbox

# Public base URL of the app (required) — used to build the success-page URL.
APP_URL=http://localhost:3000

# TCP port the server binds to (required) — integer between 1 and 65535.
PORT=3000
